{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react",
    "noEmit": true
  },
  "include": ["app", "components", "lib"],
  "exclude": ["node_modules", "frontend", "backend"]
}
